{
  "kind": "singleType",
  "collectionName": "brand_sections",
  "info": {
    "singularName": "brand-section",
    "pluralName": "brand-sections",
    "displayName": "Brand Section",
    "description": "Unified section for brand stats and logos"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "stats": {
      "type": "component",
      "repeatable": true,
      "component": "brand.stat"
    },
    "logos": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "heroSmall": { "type": "string" },
    "heroTitle": { "type": "string" },
    "heroDesc": { "type": "text" },
    "heroCta": { "type": "string" },
    "contactTitle": { "type": "string" },
    "contactSub": { "type": "text" },
    "whatsappNumber": { "type": "string" },
    "contactEmail": { "type": "string" },
    "siteName": { "type": "string" },
    "twitterUrl": { "type": "string" },
    "instagramUrl": { "type": "string" },
    "linkedinUrl": { "type": "string" }
  }
}
