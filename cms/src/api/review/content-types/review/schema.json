{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review",
    "description": "Client testimonials shown on the site"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "authorName": {
      "type": "string",
      "required": true
    },
    "authorInitials": {
      "type": "string",
      "maxLength": 3
    },
    "authorTitle": {
      "type": "string"
    },
    "quote": {
      "type": "text"
    },
    "type": {
      "type": "enumeration",
      "default": "text",
      "enum": [
        "text",
        "video"
      ]
    },
    "layout": {
      "type": "enumeration",
      "default": "square",
      "enum": [
        "wide",
        "tall",
        "square"
      ]
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "reviewVideo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
